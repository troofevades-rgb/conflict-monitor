TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
ANTHROPIC_API_KEY=
MAPBOX_TOKEN=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=conflict_monitor
# AISStream.io - free API key from https://aisstream.io
AISSTREAM_API_KEY=
# OpenSky API (optional) - can take 24h after signup to activate
#OPENSKY_USERNAME=
#OPENSKY_PASSWORD=
# Google Maps API key (optional) - enables photorealistic 3D Tiles in terrain view
#GOOGLE_MAPS_KEY=
# Cesium Ion token (optional) - enables world terrain elevation
#CESIUM_ION_TOKEN=
# Frontend API URL (optional) - defaults to http://localhost:8000
#VITE_API_URL=http://localhost:8000
# Demo mode - set to true to run with synthetic data, no API keys required
DEMO_MODE=false
